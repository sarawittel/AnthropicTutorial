    "postStartCommand": "cf login -a 'https://api.cf.eu10-005.hana.ondemand.com' --sso -p 'VG-ORTH GmbH & Co. KG_tech-test-dels51wp' -s 'dev' --skip-ssl-validation",
    "customizations": {
        "vscode": {
            "extensions": [
                "sapse.sap-ux-fiori-tools-extension-pack",
